# ============================================
# publi — Variables de entorno
# Copiá este archivo como .env.local y completá los valores
# NUNCA commitees .env.local al repositorio
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq
GROQ_API_KEY=

# Instagram / Meta
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# Instagram API with Instagram Login (conexión de cuentas + publicación)
#   Estos son el Instagram App ID/Secret del producto "Instagram" de tu app de
#   Meta (developers.facebook.com), distintos del App ID de Facebook de arriba.
#   La cuenta a conectar debe ser Business o Creator. Ver README → "Instagram".
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Opcional: si se setea, fija el redirect_uri del OAuth (debe matchear EXACTO el
# registrado en la app de Meta). Si no, se deriva del dominio de la request.
INSTAGRAM_REDIRECT_URI=

# Facebook Pages (conexión de cuentas + publicación)
FACEBOOK_APP_ID=          # App ID de Meta Developers (puede ser la misma app que Instagram)
FACEBOOK_APP_SECRET=      # App Secret de Meta (solo servidor)
FACEBOOK_REDIRECT_URI=    # Opcional: fija el redirect_uri del OAuth de Facebook

# Upstash QStash — scheduling de publicaciones programadas
#   PROD/PREVIEW: copiá QSTASH_URL, QSTASH_TOKEN y las 2 signing keys desde
#                 el dashboard de QStash (https://console.upstash.com/qstash).
#   LOCAL: QStash no llega a localhost. Para probar el ciclo completo, corré
#          en otra terminal:  npx @upstash/qstash-cli dev
#          y pegá acá las 4 variables (QSTASH_URL incluida) que imprime al
#          arrancar. Reiniciá `npm run dev`. Ver README → "Probar scheduling".
# QSTASH_URL=                 # solo en local: http://127.0.0.1:8080
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (Vercel) — protege /api/cron/enqueue-due. Generar con: openssl rand -hex 32
CRON_SECRET=
